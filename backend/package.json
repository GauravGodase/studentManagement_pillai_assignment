{
  "name": "student-management-backend",
  "version": "1.0.0",
  "description": "Backend REST API for the Student Management System",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "start": "node src/db/init.js && node src/index.js",
    "dev": "node --watch src/index.js",
