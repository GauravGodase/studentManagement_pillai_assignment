# Server
PORT=5000
NODE_ENV=development

# CORS - frontend origin allowed to call the API
CLIENT_ORIGIN=http://localhost:5173

# PostgreSQL connection
# Either provide a full connection string...
# DATABASE_URL=postgresql://user:password@localhost:5432/student_management
# ...or the individual parts below:
PGHOST=localhost
PGPORT=5432
PGUSER=postgres
PGPASSWORD=postgres
PGDATABASE=student_management

# Where uploaded photos are stored (relative to backend/)
UPLOAD_DIR=uploads
